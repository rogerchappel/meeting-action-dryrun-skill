{
  "name": "meeting-action-dryrun-skill",
  "version": "0.1.0",
  "description": "Turn meeting notes into proposed follow-up actions and dry-run payloads without sending messages.",
  "type": "module",
  "bin": {
    "meeting-action-dryrun": "src/cli.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "bash scripts/validate.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm run build && npm test && npm run smoke && npm run package:smoke",
    "lint": "npm run check"
  },
  "keywords": [
    "agent-skill",
    "local-first",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/meeting-action-dryrun-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/meeting-action-dryrun-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/meeting-action-dryrun-skill#readme",
  "files": [
    "src",
    "scripts",
    "fixtures",
    "docs",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
